{
  "name": "hypermarrow-desktop",
  "version": "2.0.0",
  "description": "智商藏不住 — AI 记忆与学习系统 桌面客户端",
  "main": "dist/main/index.js",
  "author": "OpenClaw Team",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run build:main -- --watch\" \"npm run dev:electron\"",
    "dev:electron": "wait-on dist/main/index.js && electron .",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:main",
    "start": "electron .",
    "pack:win": "electron-builder --win --x64",
    "pack:mac": "electron-builder --mac --x64 --arm64",
    "pack:all": "electron-builder --win --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.0",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/qrcode": "^1.5.5",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0",
    "wait-on": "^7.2.0"
  },
  "build": { "extends": "./electron-builder.yml" }
}
