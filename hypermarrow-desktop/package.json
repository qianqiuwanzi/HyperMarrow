{
  "name": "hypermarrow-desktop",
  "version": "2.1.1",
  "description": "智商藏不住 — AI 记忆与学习系统 桌面客户端",
  "main": "dist/main/index.js",
  "author": "OpenClaw Team",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run build:main -- --watch\" \"npm run dev:electron\"",
    "dev:electron": "wait-on dist/main/index.js && electron .",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:main",
    "start": "electron .",
    "prepack:win": "npm run build:main",
    "pack:win": "set ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/&& set ELECTRON_BUILDER_CACHE=%APPDATA%\\hypermarrow\\electron-builder-cache&& electron-builder --win --x64",
    "release": "node scripts/bump-version.js && npm run pack:win && node scripts/sync-product-page.js",
    "prepack:mac": "npm run build:main",
    "pack:mac": "set ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/&& set ELECTRON_BUILDER_CACHE=%APPDATA%\\hypermarrow\\electron-builder-cache&& electron-builder --mac --x64 --arm64",
    "prepack:all": "npm run build:main",
    "pack:all": "set ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/&& set ELECTRON_BUILDER_CACHE=%APPDATA%\\hypermarrow\\electron-builder-cache&& electron-builder --win --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.0",
    "qrcode": "^1.5.3",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/qrcode": "^1.5.5",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "typescript": "^5.3.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "extends": "./electron-builder.yml"
  }
}
